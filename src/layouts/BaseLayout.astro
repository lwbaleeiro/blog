---
interface Props {
  title?: string;
  activePage?: 'blog' | 'about';
}

const { title = 'Luan Baleeiro', activePage = 'blog' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Top bar -->
    <header class="topbar">
      <a href="/" class="topbar-name">Luan Baleeiro</a>
      <button class="theme-toggle" id="themeToggle" aria-label="Alternar tema">
        <span class="icon-moon">🌙</span>
        <span class="icon-sun">☀️</span>
        <span class="toggle-label">Dark</span>
      </button>
    </header>

    <!-- Layout -->
    <div class="layout">
      <aside class="sidebar">
        <slot name="sidebar" />
      </aside>
      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  const toggle = document.getElementById('themeToggle');
  const html = document.documentElement;
  const label = toggle?.querySelector('.toggle-label');

  const saved = localStorage.getItem('theme') || 'dark';
  html.setAttribute('data-theme', saved);
  if (label) label.textContent = saved === 'dark' ? 'Dark' : 'Light';

  toggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    if (label) label.textContent = next === 'dark' ? 'Dark' : 'Light';
  });
</script>

<style is:global>
  :root {
    --bg: #0d0d0d;
    --bg-card: #161616;
    --bg-sidebar: #0d0d0d;
    --border: #2a2a2a;
    --text: #e8e8e8;
    --text-muted: #888;
    --text-dim: #555;
    --accent: #4d9fff;
    --tag: #1e2d3d;
    --tag-text: #4d9fff;
    --topbar-bg: #111;
    --topbar-border: #222;
  }

  [data-theme="light"] {
    --bg: #f5f5f5;
    --bg-card: #ffffff;
    --bg-sidebar: #f5f5f5;
    --border: #e0e0e0;
    --text: #1a1a1a;
    --text-muted: #555;
    --text-dim: #999;
    --accent: #0070f3;
    --tag: #e8f0fe;
    --tag-text: #0070f3;
    --topbar-bg: #ffffff;
    --topbar-border: #e0e0e0;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.6;
  }

  body {
    min-height: 100vh;
    background: var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Topbar */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 52px;
    background: var(--topbar-bg);
    border-bottom: 1px solid var(--topbar-border);
  }

  .topbar-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--bg-card);
    color: var(--text);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
  }

  [data-theme="dark"] .icon-sun,
  [data-theme="light"] .icon-moon {
    display: none;
  }

  /* Layout */
  .layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 52px);
  }

  .sidebar {
    border-right: 1px solid var(--border);
    background: var(--bg-sidebar);
    padding: 2rem 1.5rem;
    position: sticky;
    top: 52px;
    height: calc(100vh - 52px);
    overflow-y: auto;
  }

  .content {
    padding: 2rem 2.5rem;
    max-width: 780px;
  }

  /* Prose styles for blog posts */
  .prose {
    color: var(--text);
    line-height: 1.8;
  }

  .prose h1, .prose h2, .prose h3 {
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose h1 { font-size: 1.8rem; }
  .prose h2 { font-size: 1.3rem; }
  .prose h3 { font-size: 1.1rem; }

  .prose p {
    margin-bottom: 1.2rem;
  }

  .prose ul, .prose ol {
    margin: 0.75rem 0 1.2rem 1.5rem;
  }

  .prose li {
    margin-bottom: 0.3rem;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose code {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.88em;
    font-family: 'Fira Code', monospace;
  }

  .prose pre {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: none;
    border: none;
    padding: 0;
  }

  @media (max-width: 768px) {
    .layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.5rem;
    }

    .content {
      padding: 1.5rem;
    }
  }
</style>
